      "name": "Clean Records"
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const r = item.json;\n\n  const issueSummary = Array.isArray(r.issues) ? r.issues.join(\"; \") : r.issues;\n\n  return {\n    json: {\n      ...r,\n      process_result: \"Urgent Escalation\",\n      output_type: \"Same-day control alert\",\n      human_action_required: \"Yes\",\n      escalation_required: \"Yes\",\n      sla: \"Same day\",\n      action_owner: \"Finance control / process owner\",\n      issue_summary: issueSummary,\n      business_decision: \"Block posting, payment, or closure until reviewed.\",\n      control_status: \"Blocked pending urgent review\",\n      alert_message: `Urgent finance control review required for ${r.invoice_id}. Do not process further before review.`\n    }\n  };\n});"
      },
