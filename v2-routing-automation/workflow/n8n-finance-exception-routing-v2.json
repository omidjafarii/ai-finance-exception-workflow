        "jsCode": "return items.map(item => {\n  const r = item.json;\n\n  return {\n    json: {\n      ...r,\n      process_route: \"Normal Processing\",\n      human_action_required: \"No\",\n      escalation_required: \"No\",\n      sla: \"Not applicable\",\n      business_decision: \"Continue normal finance process\",\n      next_action: \"No manual review needed. Record can continue through normal processing.\",\n      control_status: \"Cleared\"\n    }\n  };\n});"
      },
