    {
      "parameters": {
        "jsCode": "return [\n  {\n    json: {\n      timestamp: new Date().toISOString(),\n      invoice_id: \"INV-1001\",\n      supplier_name: \"Nordic Office Supplies\",\n      supplier_vat: \"FI12345678\",\n      invoice_date: \"2026-07-01\",\n      due_date: \"2026-07-15\",\n      net_amount: 1000,\n      vat_amount: 240,\n      total_amount: 1240,\n      currency: \"EUR\",\n      status: \"paid\",\n      payment_date: \"2026-07-10\",\n      account_code: \"6100\"\n    }\n  },\n  {\n    json: {\n      timestamp: new Date().toISOString(),\n      invoice_id: \"INV-1002\",\n      supplier_name: \"Helsinki IT Services\",\n      supplier_vat: \"\",\n      invoice_date: \"2026-07-02\",\n      due_date: \"2026-07-16\",\n      net_amount: 800,\n      vat_amount: 192,\n      total_amount: 992,\n      currency: \"EUR\",\n      status: \"unpaid\",\n      payment_date: \"\",\n      account_code: \"6200\"\n    }\n  },\n  {\n    json: {\n      timestamp: new Date().toISOString(),\n      invoice_id: \"INV-1003\",\n      supplier_name: \"Tampere Consulting\",\n      supplier_vat: \"FI87654321\",\n      invoice_date: \"2026-07-04\",\n      due_date: \"2026-07-03\",\n      net_amount: 500,\n      vat_amount: 120,\n      total_amount: 620,\n      currency: \"EUR\",\n      status: \"unpaid\",\n      payment_date: \"\",\n      account_code: \"6300\"\n    }\n  },\n  {\n    json: {\n      timestamp: new Date().toISOString(),\n      invoice_id: \"INV-1004\",\n      supplier_name: \"Nordic Office Supplies\",\n      supplier_vat: \"FI12345678\",\n      invoice_date: \"2026-07-01\",\n      due_date: \"2026-07-15\",\n      net_amount: 1000,\n      vat_amount: 240,\n      total_amount: 1240,\n      currency: \"EUR\",\n      status: \"paid\",\n      payment_date: \"2026-07-10\",\n      account_code: \"6100\"\n    }\n  },\n  {\n    json: {\n      timestamp: new Date().toISOString(),\n      invoice_id: \"INV-1005\",\n      supplier_name: \"Payroll Partner Oy\",\n      supplier_vat: \"FI55555555\",\n      invoice_date: \"2026-07-05\",\n      due_date: \"2026-07-20\",\n      net_amount: 1200,\n      vat_amount: 250,\n      total_amount: 1450,\n      currency: \"EUR\",\n      status: \"paid\",\n      payment_date: \"\",\n      account_code: \"6400\"\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
