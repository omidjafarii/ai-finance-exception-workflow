      "id": "14854068-0619-4d3a-947e-4e046edb765b",
      "name": "Create Sample Finance Data"
    },
    {
      "parameters": {
        "jsCode": "const invoices = items.map(item => item.json);\n\nconst invoiceCounts = {};\nfor (const invoice of invoices) {\n  invoiceCounts[invoice.invoice_id] = (invoiceCounts[invoice.invoice_id] || 0) + 1;\n}\n\nfunction parseDate(value) {\n  if (!value) return null;\n  return new Date(value);\n}\n\nfunction round2(value) {\n  return Math.round(Number(value) * 100) / 100;\n}\n\nfunction getSuggestedAction(issues) {\n  const issueText = issues.join(\" \").toLowerCase();\n\n  if (issueText.includes(\"duplicate\")) {\n    return \"Check source system before posting or payment.\";\n  }\n\n  if (issueText.includes(\"vat\")) {\n    return \"Verify VAT calculation and supplier invoice details.\";\n  }\n\n  if (issueText.includes(\"payment date\")) {\n    return \"Confirm payment date from bank or payment system.\";\n  }\n\n  if (issueText.includes(\"due date\")) {\n    return \"Confirm invoice date and payment terms.\";\n  }\n\n  if (issueText.includes(\"account code\")) {\n    return \"Confirm correct account code before posting.\";\n  }\n\n  if (issueText.includes(\"supplier vat\")) {\n    return \"Check vendor master data or request missing supplier VAT number.\";\n  }\n\n  return \"Finance team should review missing or inconsistent data.\";\n}\n\nfunction getCategory(issues) {\n  const issueText = issues.join(\" \").toLowerCase();\n\n  if (issueText.includes(\"duplicate\")) return \"Duplicate risk\";\n  if (issueText.includes(\"vat\")) return \"VAT / tax validation\";\n  if (issueText.includes(\"payment\")) return \"Reconciliation\";\n  if (issueText.includes(\"due date\")) return \"Date validation\";\n  if (issueText.includes(\"account code\")) return \"Accounting coding\";\n  if (issueText.includes(\"supplier\")) return \"Vendor data quality\";\n\n  return \"Data quality\";\n}\n\nfunction getReviewNote(invoice, issues, priority) {\n  if (issues.length === 0) {\n    return \"No exception detected. This record appears ready for normal finance processing.\";\n  }\n\n  return `This record needs ${priority.toLowerCase()} priority review because: ${issues.join(\"; \")}. Suggested next step: ${getSuggestedAction(issues)}`;\n}\n\nconst validated = invoices.map(invoice => {\n  const issues = [];\n\n  const expectedVat = round2(invoice.net_amount * 0.24);\n  const expectedTotal = round2(invoice.net_amount + invoice.vat_amount);\n\n  const invoiceDate = parseDate(invoice.invoice_date);\n  const dueDate = parseDate(invoice.due_date);\n\n  if (!invoice.invoice_id) {\n    issues.push(\"Missing invoice ID\");\n  }\n\n  if (!invoice.supplier_vat) {\n    issues.push(\"Missing supplier VAT number\");\n  }\n\n  if (invoiceCounts[invoice.invoice_id] > 1) {\n    issues.push(\"Possible duplicate invoice ID\");\n  }\n\n  if (invoiceDate && dueDate && dueDate < invoiceDate) {\n    issues.push(\"Due date is before invoice date\");\n  }\n\n  if (round2(invoice.vat_amount) !== expectedVat) {\n    issues.push(`VAT mismatch: expected ${expectedVat}, found ${invoice.vat_amount}`);\n  }\n\n  if (round2(invoice.total_amount) !== expectedTotal) {\n    issues.push(`Total mismatch: expected ${expectedTotal}, found ${invoice.total_amount}`);\n  }\n\n  if (String(invoice.status).toLowerCase() === \"paid\" && !invoice.payment_date) {\n    issues.push(\"Invoice marked as paid but payment date is missing\");\n  }\n\n  if (!invoice.account_code) {\n    issues.push(\"Missing account code\");\n  }\n\n  let reviewStatus = \"OK\";\n  let priority = \"Low\";\n\n  if (issues.length === 1) {\n    reviewStatus = \"Needs Review\";\n    priority = \"Medium\";\n  }\n\n  if (issues.length >= 2) {\n    reviewStatus = \"Exception\";\n    priority = \"High\";\n  }\n\n  const category = getCategory(issues);\n  const suggestedAction = getSuggestedAction(issues);\n  const reviewNote = getReviewNote(invoice, issues, priority);\n\n  return {\n    json: {\n      timestamp: invoice.timestamp,\n      invoice_id: invoice.invoice_id,\n      supplier_name: invoice.supplier_name,\n      total_amount: invoice.total_amount,\n      currency: invoice.currency,\n      review_status: reviewStatus,\n      priority,\n      exception_category: category,\n      issues: issues.length ? issues.join(\"; \") : \"No issue\",\n      suggested_action: suggestedAction,\n      review_note: reviewNote\n    }\n  };\n});\n\nreturn validated;"
      },
