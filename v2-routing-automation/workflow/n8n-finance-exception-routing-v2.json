      "parameters": {
        "jsCode": "return items.map(item => {\n  const r = item.json;\n\n  const issueSummary = Array.isArray(r.issues) ? r.issues.join(\"; \") : r.issues;\n\n  return {\n    json: {\n      ...r,\n      process_result: \"Standard Review\",\n      output_type: \"Finance review task\",\n      human_action_required: \"Yes\",\n      escalation_required: \"No\",\n      sla: \"2-3 business days\",\n      action_owner: \"Finance review queue\",\n      issue_summary: issueSummary,\n      business_decision: \"Send to standard finance review before final processing.\",\n      control_status: \"Pending standard review\",\n      task_note: r.review_note || r.suggested_action || \"Finance should review this item during the normal review cycle.\"\n    }\n  };\n});"
      },
